  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">/* Main background */
QWidget {
    background-color: #18181b;
    color: white;
}

/* ALL cards base style */
QFrame {
    background-color: #27272a;
    border: 1px solid #3f3f46;
    border-radius: 14px;
}

QWidget {
    background-color: #18181b;
    color: white;
}

QFrame#overviewCard,
QFrame#petsCard,
QFrame#notificationsCard,
QFrame#activityCard {
    background-color: #27272a;
    border: 1px solid #3f3f46;
    border-radius: 14px;
}

/* Specific cards (optional tweaks) */
QFrame#overviewCard {
    background-color: #2d2d32;
}

QFrame#petsCard {
    background-color: #2a2a30;
}

QFrame#notificationsCard {
    background-color: #2a2a30;
}

QFrame#activityCard {
    background-color: #26262b;
}

QLabel {
    background: transparent;
    border: none;
    color: white;
}

/* Buttons */
QPushButton {
    background-color: #313135;
    color: white;
    border: 1px solid #45454d;
    border-radius: 10px;
    padding: 8px 12px;
}

QPushButton:hover {
    background-color: #3d3d44;
}</string>
   </property>
